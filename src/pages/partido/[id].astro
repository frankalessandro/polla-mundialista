---
import Layout from '../../layouts/Layout.astro';
import PredictionsTable from '../../components/PredictionsTable.astro';
import Flag from '../../components/Flag.astro';
import LiveBadge from '../../components/LiveBadge.astro';
import { getMatches } from '../../lib/matchSource.ts';
import { predictionsForMatch } from '../../lib/views.ts';
import { participants } from '../../data/participants.ts';

export async function getStaticPaths() {
  const matches = await getMatches();
  return matches.map((m) => ({ params: { id: String(m.id) }, props: { match: m } }));
}

const { match } = Astro.props;
const played = match.result !== null;
const live = match.live === true;
const rows = predictionsForMatch(match, participants);
---

<Layout title={`${match.home} vs ${match.away}`}>
	<p class="back reveal"><a href="/partidos">← Partidos</a></p>

	<div class="header reveal">
		<div class="badges">
			<span class="group">Grupo {match.group}</span>
			{live && <LiveBadge />}
		</div>
		<div class="teams">
			<span class="team home">
				<span class="tname">{match.home}</span>
				<Flag team={match.home} size={34} />
			</span>
			<span class={`score ${played ? 'played' : ''} ${live ? 'live' : ''}`}>
				{played ? `${match.result!.home} - ${match.result!.away}` : 'vs'}
			</span>
			<span class="team away">
				<Flag team={match.away} size={34} />
				<span class="tname">{match.away}</span>
			</span>
		</div>
		<p class="meta">
			{match.date} · {match.time} · {match.stadium}
			{!played && !live && ' · Programado'}
		</p>
	</div>

	{
		live && (
			<p class="live-note reveal">
				Partido en vivo: el marcador es parcial y los puntos mostrados son
				<strong> provisionales</strong>, pueden cambiar hasta el final.
			</p>
		)
	}

	<h2 class="reveal">Apuestas <span class="count">{rows.length}</span></h2>
	<div class="card reveal" style="animation-delay:.06s">
		<PredictionsTable rows={rows} played={played} />
	</div>
</Layout>

<style>
	.back {
		margin: 0 0 1rem;
	}

	.header {
		background: var(--grad-soft);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.5rem;
		margin-bottom: 1.5rem;
		text-align: center;
		box-shadow: var(--shadow-sm);
	}

	.badges {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}

	.group {
		font-size: 0.74rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--primary);
	}

	.teams {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		font-size: 1.3rem;
		font-weight: 700;
	}

	.team {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		min-width: 0;
	}

	.team.home {
		justify-content: flex-end;
		text-align: right;
	}

	.team.away {
		justify-content: flex-start;
		text-align: left;
	}

	.score {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 2.6rem;
		letter-spacing: 0.04em;
		color: var(--muted);
		line-height: 1;
	}

	.score.played {
		color: var(--primary);
	}

	.score.live {
		color: var(--live);
	}

	.meta {
		margin: 1rem 0 0;
		color: var(--muted);
		font-size: 0.9rem;
		font-weight: 500;
	}

	.live-note {
		background: rgba(255, 93, 122, 0.08);
		border: 1px solid rgba(255, 93, 122, 0.35);
		border-radius: 12px;
		padding: 0.75rem 1rem;
		margin: 0 0 1.5rem;
		font-size: 0.9rem;
		color: var(--text);
	}

	h2 {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-size: 1.5rem;
		margin: 0 0 0.9rem;
	}

	.count {
		font-family: 'Outfit', sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		color: #fff;
		background: var(--grad);
		border-radius: 999px;
		padding: 0.15rem 0.6rem;
	}

	@media (max-width: 520px) {
		.score {
			font-size: 2rem;
		}
		.teams {
			font-size: 1.05rem;
		}
	}
</style>
