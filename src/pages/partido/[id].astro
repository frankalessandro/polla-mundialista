---
import Layout from '../../layouts/Layout.astro';
import PredictionsTable from '../../components/PredictionsTable.astro';
import LiveBadge from '../../components/LiveBadge.astro';
import MatchScore from '../../components/MatchScore.astro';
import { getMatches } from '../../lib/matchSource.ts';
import { predictionsForMatch, standingsImpactForMatch } from '../../lib/views.ts';
import { participants } from '../../data/participants.ts';

export async function getStaticPaths() {
  const matches = await getMatches();
  return matches.map((m) => ({ params: { id: String(m.id) }, props: { match: m, allMatches: matches } }));
}

const { match, allMatches } = Astro.props;
const played = match.result !== null;
const live = match.live === true;
const rows = predictionsForMatch(match, participants);
const impact = played ? standingsImpactForMatch(match.id, allMatches, participants) : undefined;
---

<Layout title={`${match.home} vs ${match.away}`}>
  <p class="reveal mb-4"><a href="/">← Partidos</a></p>

  <div class="reveal border border-border rounded-2xl p-6 mb-6 text-center [background:var(--grad-soft)] [box-shadow:var(--shadow-sm)]">
    <div class="flex items-center justify-center gap-2.5 mb-4">
      <span class="text-[.74rem] font-bold uppercase tracking-[.08em] text-primary">Grupo {match.group}</span>
      {live && <LiveBadge />}
    </div>

    <MatchScore home={match.home} away={match.away} result={match.result} live={live} size="lg" />

    <p class="mt-4 mb-0 text-muted text-[.9rem] font-medium">
      {match.date} · {match.time} · {match.stadium}
      {!played && !live && ' · Programado'}
    </p>
  </div>

  {live && (
    <p class="reveal bg-[rgba(255,93,122,.08)] border border-[rgba(255,93,122,.35)] rounded-xl px-4 py-3 mb-6 text-[.9rem] text-text">
      Partido en vivo: el marcador es parcial y los puntos mostrados son
      <strong> provisionales</strong>, pueden cambiar hasta el final.
    </p>
  )}

  <h2 class="reveal flex items-center gap-2 text-[1.5rem] mb-3.5">
    Apuestas
    <span class="font-['Outfit'] text-[.8rem] font-bold text-white [background:var(--grad)] rounded-full px-2.5 py-0.5">{rows.length}</span>
  </h2>

  <div class="card reveal" style="animation-delay:.06s">
    <PredictionsTable rows={rows} played={played} match={match} impact={impact} />
  </div>
</Layout>
