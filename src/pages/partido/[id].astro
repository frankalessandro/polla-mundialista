---
import Layout from '../../layouts/Layout.astro';
import PredictionsTable from '../../components/PredictionsTable.astro';
import Flag from '../../components/Flag.astro';
import { getMatches } from '../../lib/matchSource.ts';
import { predictionsForMatch } from '../../lib/views.ts';
import { participants } from '../../data/participants.ts';

export async function getStaticPaths() {
  const matches = await getMatches();
  return matches.map((m) => ({ params: { id: String(m.id) }, props: { match: m } }));
}

const { match } = Astro.props;
const played = match.result !== null;
const live = match.live === true;
const rows = predictionsForMatch(match, participants);
---

<Layout title={`${match.home} vs ${match.away}`}>
	<p class="subtitle"><a href="/partidos">← Partidos</a></p>

	<div class="header">
		<div class="teams">
			<span class="team home"><span>{match.home}</span> <Flag team={match.home} size={28} /></span>
			<span class={`score ${played ? 'played' : ''} ${live ? 'live' : ''}`}>
				{played ? `${match.result!.home} - ${match.result!.away}` : 'vs'}
			</span>
			<span class="team away"><Flag team={match.away} size={28} /> <span>{match.away}</span></span>
		</div>
		<p class="subtitle meta">
			Grupo {match.group} · {match.date} · {match.time} · {match.stadium}
			{live ? ' · 🔴 En vivo' : !played && ' · No jugado'}
		</p>
	</div>

	{
		live && (
			<p class="live-note">
				🔴 Partido en vivo: el marcador es parcial y los puntos mostrados son
				<strong> provisionales</strong>, pueden cambiar hasta el final.
			</p>
		)
	}

	<h2>Apuestas ({rows.length})</h2>
	<PredictionsTable rows={rows} played={played} />
</Layout>

<style>
	.header {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.25rem;
		margin-bottom: 1.5rem;
		text-align: center;
	}

	.teams {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		font-size: 1.3rem;
		font-weight: 700;
	}

	.team {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.team.home {
		justify-content: flex-end;
	}

	.team.away {
		justify-content: flex-start;
	}

	.score {
		color: var(--muted);
		font-variant-numeric: tabular-nums;
	}

	.score.played {
		color: var(--accent);
	}

	.score.live {
		color: #ff6369;
	}

	.live-note {
		background: rgba(229, 72, 77, 0.12);
		border: 1px solid #e5484d;
		border-radius: 8px;
		padding: 0.6rem 0.9rem;
		margin: 0 0 1.25rem;
		font-size: 0.9rem;
	}

	.meta {
		margin: 0.75rem 0 0;
	}

	h2 {
		font-size: 1.1rem;
		margin: 0 0 0.75rem;
	}
</style>
