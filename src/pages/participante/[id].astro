---
import Layout from '../../layouts/Layout.astro';
import Flag from '../../components/Flag.astro';
import LiveBadge from '../../components/LiveBadge.astro';
import { getMatches } from '../../lib/matchSource.ts';
import { breakdownForParticipant } from '../../lib/views.ts';
import { buildStandings } from '../../lib/scoring.ts';
import { participants } from '../../data/participants.ts';

export function getStaticPaths() {
  return participants.map((p) => ({ params: { id: String(p.id) } }));
}

const id = Number(Astro.params.id);
const participant = participants.find((p) => p.id === id)!;

const matches = await getMatches();
const breakdown = breakdownForParticipant(id, matches, participants);
const standings = buildStandings(matches, participants);
const position = standings.findIndex((r) => r.participantId === id) + 1;
const row = standings.find((r) => r.participantId === id)!;
const hasLive = breakdown.some((b) => b.match.live);
const exact = breakdown.filter((b) => b.points === 5).length;
const pointClass = (p: number) => (p >= 5 ? 'p-top' : p >= 2 ? 'p-mid' : p > 0 ? 'p-low' : 'p-zero');
---

<Layout title={participant.name}>
  <p class="reveal mb-4"><a href="/">← Clasificación</a></p>

  <section class="reveal flex items-center gap-4 border border-border rounded-2xl p-[1.35rem_1.5rem] mb-6 [background:var(--grad-soft)] [box-shadow:var(--shadow-sm)]">
    <div class="flex items-center justify-center min-w-[64px] h-16 rounded-[18px] font-['Bebas_Neue'] text-[1.9rem] text-white [background:var(--grad)] [box-shadow:var(--shadow-sm)]">
      #{position}
    </div>
    <div>
      <h1 class="text-[clamp(2rem,5vw,2.8rem)] mb-1.5 font-bold">{participant.name}</h1>
      <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-muted text-[.95rem]">
        <span class="inline-flex items-center gap-1.5">
          <b class="text-text text-[1.05rem]">{row.total}</b> puntos
          {hasLive && <LiveBadge small label="Provisional" />}
        </span>
        <span class="inline-flex items-center gap-1.5"><b class="text-text text-[1.05rem]">{exact}</b> exactos</span>
        <span class="inline-flex items-center gap-1.5"><b class="text-text text-[1.05rem]">{row.correctOutcomes}</b> aciertos</span>
      </div>
    </div>
  </section>

  {breakdown.length === 0 ? (
    <p class="reveal text-muted">
      Todavía no hay partidos jugados, así que aún no se han ganado puntos.
    </p>
  ) : (
    <div class="card reveal" style="animation-delay:.06s">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Partido</th>
              <th class="num">Apuesta</th>
              <th class="num">Resultado</th>
              <th class="num">Pts</th>
            </tr>
          </thead>
          <tbody>
            {breakdown.map((b) => (
              <tr class={b.match.live ? 'bg-[rgba(255,93,122,.06)]' : ''}>
                <td>
                  <a class="flex items-center gap-1.5 text-text font-semibold hover:text-primary transition-colors" href={`/partido/${b.match.id}`}>
                    <span class="flex-none"><Flag team={b.match.home} size={14} /></span>
                    <span class="leading-tight">{b.match.home} vs {b.match.away}</span>
                    <span class="flex-none"><Flag team={b.match.away} size={14} /></span>
                  </a>
                  {b.match.live && <LiveBadge small />}
                  <span class="block text-muted text-[.78rem] mt-0.5">
                    Grupo {b.match.group} | {b.match.date}
                  </span>
                </td>
                <td class="num bet">{b.prediction.home} - {b.prediction.away}</td>
                <td class="num bet strong">
                  {b.result
                    ? `${b.result.home} - ${b.result.away}`
                    : <span class="font-['Outfit'] text-[.78rem] font-medium text-muted tracking-normal">No jugado</span>}
                </td>
                <td class="num">
                  {b.points === null
                    ? <span class="font-['Outfit'] text-[.78rem] font-medium text-muted tracking-normal">—</span>
                    : <span class={`pts ${pointClass(b.points)}`}>{b.points}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</Layout>
