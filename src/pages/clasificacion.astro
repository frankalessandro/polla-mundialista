---
import Layout from "../layouts/Layout.astro";
import StandingsTable from "../components/StandingsTable.astro";
import ParticipantSearch from "../components/ParticipantSearch.astro";
import DesempateToggle from "../components/DesempateToggle.astro";
import InfoModal from "../components/InfoModal.astro";
import LiveBadge from "../components/LiveBadge.astro";
import Flag from "../components/Flag.astro";
import { getMatches } from "../lib/matchSource.ts";
import { getLeagueBadge } from "../lib/sportsdb.ts";
import { buildStandings } from "../lib/scoring.ts";
import { participants } from "../data/participants.ts";

const matches = await getMatches();
const leagueBadge = await getLeagueBadge();
const standings = buildStandings(matches, participants);
const playedCount = matches.filter((m) => m.result !== null).length;
const liveMatches = matches.filter((m) => m.live);
---

<Layout title="Clasificación general">
  <section
    class="hero reveal flex items-center gap-5 border border-border rounded-2xl p-[1.5rem_1.75rem] mb-6 [background:var(--grad-soft)] [box-shadow:var(--shadow-sm)] max-[540px]:flex-col max-[540px]:text-center"
  >
    <img
      src={leagueBadge}
      alt="FIFA World Cup"
      class="h-[92px] w-auto [filter:drop-shadow(0_8px_16px_rgba(110,80,190,.28))] [animation:float_4s_ease-in-out_infinite]"
    />
    <div>
      <p
        class="m-0 font-bold text-[.78rem] tracking-[.14em] uppercase text-primary"
      >
        Copa del Mundo 2026
      </p>
      <h1>Clasificación</h1>
      <p class="text-muted mt-1.5 mb-0 font-medium">
        {participants.length} participantes · {playedCount} de {matches.length} partidos
        jugados
      </p>
    </div>
  </section>

  {
    liveMatches.length > 0 && (
      <div class="reveal mb-6">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="text-[.85rem] text-muted font-medium">Clasificación provisional — los puntos pueden cambiar</span>
        </div>
        <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-3.5">
          {liveMatches.map((m) => (
            <a
              href={`/partido/${m.id}`}
              class="live-card block bg-surface border border-[rgba(255,93,122,.45)] rounded-2xl p-[.9rem_1.05rem] text-text transition-[transform,box-shadow] duration-200 hover:-translate-y-1"
            >
              <div class="flex items-center justify-between mb-2.5">
                <span class="text-[.72rem] font-bold uppercase tracking-[.06em] text-primary">
                  Grupo {m.group}
                </span>
                <LiveBadge small />
              </div>
              <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2.5">
                <span class="flex items-center justify-end gap-2 font-semibold min-w-0 text-right">
                  <span class="overflow-hidden text-ellipsis whitespace-nowrap min-w-0">{m.home}</span>
                  <Flag team={m.home} size={22} />
                </span>
                <span class="font-['Bebas_Neue'] text-2xl tracking-[.04em] text-live min-w-[3.2rem] text-center">
                  {m.result!.home} - {m.result!.away}
                </span>
                <span class="flex items-center gap-2 font-semibold min-w-0">
                  <Flag team={m.away} size={22} />
                  <span class="overflow-hidden text-ellipsis whitespace-nowrap min-w-0">{m.away}</span>
                </span>
              </div>
              <div class="flex justify-between gap-2 mt-3 pt-2.5 border-t border-dashed border-border text-muted text-[.78rem]">
                <span>{m.date} · {m.time}</span>
                <span class="text-right overflow-hidden text-ellipsis whitespace-nowrap">{m.stadium}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )
  }

  {
    playedCount === 0 && (
      <p class="reveal bg-surface border border-border border-l-4 border-l-primary-2 rounded-xl p-[.85rem_1.1rem] text-muted mb-6">
        Aún no hay resultados cargados: todos los puntajes están en cero hasta
        que se jueguen los partidos.
      </p>
    )
  }

  <div class="mb-4">
    <ParticipantSearch />
  </div>

  <div class="mb-4">
    <DesempateToggle />
  </div>

  <InfoModal />

  <div class="card reveal" style="animation-delay:.08s">
    <StandingsTable rows={standings} />
  </div>
</Layout>
