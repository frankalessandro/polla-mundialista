---
import '../styles/global.css';
import { getLeagueBadge } from '../lib/sportsdb.ts';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = 'Sigue la polla mundialista de la Copa del Mundo 2026. Apuestas, clasificación y resultados en tiempo real.' } = Astro.props;
const fullTitle = title ? `${title} · Polla Mundialista` : 'Polla Mundialista · Apuestas y Puntos Copa del Mundo 2026';
const ogImage = new URL('/og-banner.png', Astro.site).toString();
const canonicalUrl = Astro.url.href;
const leagueBadge = await getLeagueBadge();
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/Ball.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Polla Mundialista" />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1424" />
		<meta property="og:image:height" content="752" />
		<meta property="og:image:alt" content="Polla Mundialista · Copa del Mundo 2026" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
	</head>
	<body>
		<!-- Líneas de cancha decorativas -->
		<div
			class="fixed inset-0 -z-10 pointer-events-none opacity-50"
			style="background: radial-gradient(circle at 50% -10%, rgba(176,139,255,.18), transparent 45%), radial-gradient(circle at 100% 100%, rgba(255,158,210,.16), transparent 40%), radial-gradient(circle at 0% 80%, rgba(79,214,166,.12), transparent 40%)"
			aria-hidden="true"
		></div>

		<!-- Header -->
		<header class="sticky top-0 z-50 flex items-center justify-between gap-4 px-5 py-2.5 border-b border-border backdrop-blur-[12px]"
			style="background: rgba(255,255,255,.82)">
			<a href="/" class="flex items-center gap-2.5 brand">
				<img src={leagueBadge} alt="FIFA World Cup" class="h-[42px] w-auto brand-logo"
					style="filter: drop-shadow(0 3px 6px rgba(110,80,190,.25)); transition: transform .3s ease" />
				<span class="font-['Bebas_Neue'] text-[1.4rem] leading-[.92] tracking-[.03em] brand-name"
					style="background: var(--grad); -webkit-background-clip: text; background-clip: text; color: transparent">
					Polla<br />Mundialista
				</span>
			</a>
			<nav class="flex gap-1.5">
				<a href="/"
					class={`font-semibold text-[.95rem] px-4 py-[.45rem] rounded-full transition-all duration-200 ${isActive('/') ? 'text-white shadow-sm' : 'text-muted hover:text-text hover:bg-surface-2'}`}
					style={isActive('/') ? 'background: var(--grad)' : ''}>
					Partidos
				</a>
				<a href="/clasificacion"
					class={`font-semibold text-[.95rem] px-4 py-[.45rem] rounded-full transition-all duration-200 ${isActive('/clasificacion') ? 'text-white shadow-sm' : 'text-muted hover:text-text hover:bg-surface-2'}`}
					style={isActive('/clasificacion') ? 'background: var(--grad)' : ''}>
					Clasificación
				</a>
			</nav>
		</header>

		<main class="max-w-[980px] mx-auto px-5 pt-7 pb-12 max-sm:px-3.5 max-sm:pt-4">
			<slot />
		</main>

		<footer class="flex items-center justify-center gap-2.5 px-4 py-8 text-muted text-sm">
			<img src={leagueBadge} alt="" class="h-[26px] opacity-70" />
			<span>Polla Mundialista · Copa del Mundo 2026 · <a href="https://alessandro-web.vercel.app/" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">@frankalessandro</a></span>
		</footer>

		<Analytics />

	<div id="nav-loader" aria-hidden="true">
			<img src="/Ball.png" alt="" class="nav-ball" />
		</div>
	</body>
</html>

<script>
	document.querySelectorAll<HTMLElement>('.table-scroll').forEach(el => {
		el.addEventListener('scroll', () => el.classList.add('is-scrolled'), { once: true });
	});

	const loader = document.getElementById('nav-loader')!;

	document.addEventListener('click', (e) => {
		const anchor = (e.target as Element).closest('a');
		if (!anchor) return;
		const href = anchor.getAttribute('href');
		if (!href || href.startsWith('#') || href.startsWith('http') || anchor.target === '_blank') return;
		loader.classList.add('is-visible');
	});

	window.addEventListener('pageshow', () => loader.classList.remove('is-visible'));
</script>

<style>
	.brand:hover .brand-logo {
		transform: rotate(-6deg) scale(1.06);
	}
</style>
