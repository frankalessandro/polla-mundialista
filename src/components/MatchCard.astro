---
import type { Match } from '../data/matches.ts';
import LiveBadge from './LiveBadge.astro';
import MatchScore from './MatchScore.astro';

interface Props {
  match: Match;
}

const { match } = Astro.props;
const played = match.result !== null;
const live = match.live === true;
---

<a
  href={`/partido/${match.id}`}
  class={`match-card block bg-surface border rounded-2xl p-[.9rem_1.05rem] text-text [box-shadow:var(--shadow-sm)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-1 hover:[box-shadow:var(--shadow)] ${live ? 'border-[rgba(255,93,122,.4)]' : 'border-border hover:border-primary-2'}`}
>
  <div class="flex items-center justify-between mb-2.5">
    <span class="text-[.72rem] font-bold uppercase tracking-[.06em] text-primary">
      Grupo {match.group}
    </span>
    {live ? <LiveBadge small /> : !played && (
      <span class="text-[.66rem] uppercase tracking-[.05em] text-muted bg-surface-2 rounded-full px-2 py-0.5">
        Programado
      </span>
    )}
  </div>

  <MatchScore home={match.home} away={match.away} result={match.result} live={live} />

  <div class="flex justify-between gap-2 mt-3 pt-2.5 border-t border-dashed border-border text-muted text-[.78rem]">
    <span>{match.date} · {match.time}</span>
    <span class="text-right overflow-hidden text-ellipsis whitespace-nowrap">{match.stadium}</span>
  </div>
</a>
