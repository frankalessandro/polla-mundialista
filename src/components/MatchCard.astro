---
import type { Match } from '../data/matches.ts';
import Flag from './Flag.astro';
import LiveBadge from './LiveBadge.astro';

interface Props {
  match: Match;
}

const { match } = Astro.props;
const played = match.result !== null;
const live = match.live === true;
---

<a href={`/partido/${match.id}`} class={`match-card ${live ? 'is-live' : ''}`}>
	<div class="top">
		<span class="group">Grupo {match.group}</span>
		{live ? <LiveBadge small /> : !played && <span class="tag">Programado</span>}
	</div>
	<div class="teams">
		<span class="team home">
			<span class="tname">{match.home}</span>
			<Flag team={match.home} size={22} />
		</span>
		<span class={`score ${played ? 'played' : ''} ${live ? 'live' : ''}`}>
			{played ? `${match.result!.home} - ${match.result!.away}` : 'vs'}
		</span>
		<span class="team away">
			<Flag team={match.away} size={22} />
			<span class="tname">{match.away}</span>
		</span>
	</div>
	<div class="meta">
		<span>{match.date} · {match.time}</span>
		<span class="stadium">{match.stadium}</span>
	</div>
</a>

<style>
	.match-card {
		display: block;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 0.9rem 1.05rem;
		color: var(--text);
		box-shadow: var(--shadow-sm);
		transition:
			transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}

	.match-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow);
		border-color: var(--primary-2);
	}

	.match-card.is-live {
		border-color: rgba(255, 93, 122, 0.4);
	}

	.top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.6rem;
	}

	.group {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--primary);
	}

	.tag {
		font-size: 0.66rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--muted);
		background: var(--surface-2);
		border-radius: 999px;
		padding: 0.1rem 0.55rem;
	}

	.teams {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 0.6rem;
	}

	.team {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		min-width: 0;
	}

	.team.home {
		justify-content: flex-end;
		text-align: right;
	}

	.team.away {
		justify-content: flex-start;
	}

	.tname {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		min-width: 0;
	}

	@media (max-width: 360px) {
		.score {
			font-size: 1.2rem;
			min-width: 2.4rem;
		}

		.team {
			font-size: 0.85rem;
		}
	}

	.score {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.5rem;
		letter-spacing: 0.04em;
		color: var(--muted);
		min-width: 3.2rem;
		text-align: center;
	}

	.score.played {
		color: var(--primary);
	}

	.score.live {
		color: var(--live);
	}

	.meta {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem 0.9rem;
		margin-top: 0.7rem;
		padding-top: 0.6rem;
		border-top: 1px dashed var(--border);
		color: var(--muted);
		font-size: 0.78rem;
	}

	.stadium {
		text-align: right;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>
