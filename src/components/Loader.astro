---
interface Props {
  size?: string;
}
const { size = '2.5rem' } = Astro.props;
---

<div class="flex justify-center items-center p-8" aria-label="Cargando…" role="status">
  <img src="/Ball.png" alt="" class="ball" style={`width:${size};height:${size}`} />
</div>

<style>
  .ball { animation: roll 0.8s linear infinite; }
</style>
