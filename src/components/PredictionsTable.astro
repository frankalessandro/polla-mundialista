---
import type { MatchPredictionRow, MatchImpact } from "../lib/views.ts";
import type { Match } from "../data/matches.ts";

interface Props {
  rows: MatchPredictionRow[];
  played: boolean;
  match: Match;
  impact?: Map<number, MatchImpact>;
}

const { rows, played, impact } = Astro.props;

const rankClass = (rank: number) =>
  rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : 'bg-surface-2 text-muted';
const pointClass = (p: number | null) =>
  p === null
    ? ""
    : p >= 5
      ? "p-top"
      : p >= 2
        ? "p-mid"
        : p > 0
          ? "p-low"
          : "p-zero";
---

<div class="bg-surface rounded-lg p-4">
  <div class="relative mb-4">
    <svg
      class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none transition-colors peer-focus:text-primary"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"></circle>
      <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
    </svg>
    <input
      id="pred-search"
      type="search"
      placeholder="Buscar participante…"
      autocomplete="off"
      spellcheck="false"
      class="peer w-full pl-10 pr-4 py-2.5 border-[1.5px] border-border rounded-xl bg-surface-2 text-text font-medium text-[.9rem] outline-none transition-[border-color,box-shadow,background] placeholder:text-muted placeholder:font-normal focus:bg-surface focus:border-primary focus:[box-shadow:0_0_0_3px_rgba(124,92,255,.14),var(--shadow-sm)] [&::-webkit-search-cancel-button]:hidden"
    />
  </div>

  <div class="table-scroll">
    <table id="pred-table">
      <thead>
        <tr>
          <th>Participante</th>
          <th class="num">Apuesta</th>
          {played && (
            <th class="num" data-col="pts" data-sort="desc">
              Puntos
              <svg class="sort-icon" viewBox="0 0 8 12" width="8" height="12" aria-hidden="true">
                <path class="up" d="M4 0L0 5h8z" /><path class="down" d="M4 12L0 7h8z" />
              </svg>
            </th>
          )}
          {impact && (
            <th class="num" data-col="rank" data-sort="asc" title="Posición en la clasificación general">
              Pos.
              <svg class="sort-icon" viewBox="0 0 8 12" width="8" height="12" aria-hidden="true">
                <path class="up" d="M4 0L0 5h8z" /><path class="down" d="M4 12L0 7h8z" />
              </svg>
            </th>
          )}
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => {
            const imp = impact?.get(row.participantId);
            return (
              <tr data-name={row.name.toLowerCase()} data-pts={row.points ?? -1} data-rank={imp?.rank ?? 9999} data-home={row.home} data-away={row.away}>
                <td>
                  <a
                    href={`/participante/${row.participantId}`}
                    class="text-text font-semibold hover:text-primary transition-colors"
                  >
                    {row.name}
                  </a>
                </td>
                <td class="num bet">
                  {row.home} - {row.away}
                </td>
                {played && (
                  <td class="num">
                    <span class={`pts ${pointClass(row.points)}`}>
                      {row.points}
                    </span>
                  </td>
                )}
                {imp && (
                  <td class="num">
                    <div class="rank-cell">
                      <span class={`rank-badge ${rankClass(imp.rank)}`}>
                        #{imp.rank}
                      </span>
                      {imp.change > 0 && (
                        <span class="delta up">↑{imp.change}</span>
                      )}
                      {imp.change < 0 && (
                        <span class="delta down">↓{Math.abs(imp.change)}</span>
                      )}
                      {imp.change === 0 && (
                        <span class="delta neutral">—</span>
                      )}
                    </div>
                  </td>
                )}
              </tr>
            );
          })
        }
        <tr id="pred-no-results" style="display:none">
          <td colspan="4" class="text-center text-muted py-6 text-[.9rem]">
            No se encontró ningún participante.
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  // ── Buscador ──────────────────────────────────────────────
  const input = document.getElementById("pred-search") as HTMLInputElement;
  const noResults = document.getElementById("pred-no-results") as HTMLTableRowElement;

  function applyFilter() {
    const q = input.value.trim().toLowerCase();
    const dataRows = document.querySelectorAll<HTMLTableRowElement>("tr[data-name]");
    let visible = 0;
    dataRows.forEach((row) => {
      const match = !q || row.dataset.name!.includes(q);
      row.style.display = match ? "" : "none";
      if (match) visible++;
    });
    noResults.style.display = visible === 0 ? "" : "none";
  }

  input?.addEventListener("input", applyFilter);

  // ── Ordenación ────────────────────────────────────────────
  const table = document.getElementById("pred-table") as HTMLTableElement;
  const tbody = table?.querySelector("tbody")!;
  let activeCol = "pts";
  let activeDir: "asc" | "desc" = "desc";

  function sortBy(col: string, dir: "asc" | "desc") {
    activeCol = col;
    activeDir = dir;

    table.querySelectorAll<HTMLElement>("th[data-col]").forEach((th) => th.removeAttribute("data-sort"));
    table.querySelector<HTMLElement>(`th[data-col="${col}"]`)?.setAttribute("data-sort", dir);

    tbody.style.opacity = "0";
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const dataRows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>("tr[data-name]"));
        dataRows.sort((a, b) => {
          const av = col === "name" ? a.dataset.name! : col === "rank" ? Number(a.dataset.rank) : Number(a.dataset.pts);
          const bv = col === "name" ? b.dataset.name! : col === "rank" ? Number(b.dataset.rank) : Number(b.dataset.pts);
          if (av < bv) return dir === "asc" ? -1 : 1;
          if (av > bv) return dir === "asc" ? 1 : -1;
          // Desempate: agrupar predicciones iguales
          const homeDiff = Number(a.dataset.home) - Number(b.dataset.home);
          if (homeDiff !== 0) return homeDiff;
          return Number(a.dataset.away) - Number(b.dataset.away);
        });
        dataRows.forEach((r) => tbody.appendChild(r));
        applyFilter();
        tbody.style.opacity = "1";
      });
    });
  }

  table?.querySelector("thead")!.addEventListener("click", (e) => {
    const th = (e.target as Element).closest<HTMLElement>("th[data-col]");
    if (!th) return;
    const col = th.dataset.col!;
    const dir = activeCol === col && activeDir === "desc" ? "asc" : "desc";
    sortBy(col, dir);
  });
</script>

