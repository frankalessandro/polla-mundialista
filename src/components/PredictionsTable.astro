---
import type { MatchPredictionRow } from "../lib/views.ts";

interface Props {
  rows: MatchPredictionRow[];
  played: boolean;
}

const { rows, played } = Astro.props;
const pointClass = (p: number | null) =>
  p === null
    ? ""
    : p >= 5
      ? "p-top"
      : p >= 2
        ? "p-mid"
        : p > 0
          ? "p-low"
          : "p-zero";
---

<div class="bg-surface rounded-lg p-4">
  <div class="relative mb-4">
    <svg
      class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none transition-colors peer-focus:text-primary"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"
      ></circle>
      <path
        d="M13 13l3.5 3.5"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"></path>
    </svg>
    <input
      id="pred-search"
      type="search"
      placeholder="Buscar participante…"
      autocomplete="off"
      spellcheck="false"
      class="peer w-full pl-10 pr-4 py-2.5 border-[1.5px] border-border rounded-xl bg-surface-2 text-text font-medium text-[.9rem] outline-none transition-[border-color,box-shadow,background] placeholder:text-muted placeholder:font-normal focus:bg-surface focus:border-primary focus:[box-shadow:0_0_0_3px_rgba(124,92,255,.14),var(--shadow-sm)] [&::-webkit-search-cancel-button]:hidden"
    />
  </div>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Participante</th>
          <th class="num">Apuesta</th>
          {played && <th class="num">Puntos</th>}
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr data-name={row.name.toLowerCase()}>
              <td>
                <a
                  href={`/participante/${row.participantId}`}
                  class="text-text font-semibold hover:text-primary transition-colors"
                >
                  {row.name}
                </a>
              </td>
              <td class="num bet">
                {row.home} - {row.away}
              </td>
              {played && (
                <td class="num">
                  <span class={`pts ${pointClass(row.points)}`}>
                    {row.points}
                  </span>
                </td>
              )}
            </tr>
          ))
        }
        <tr id="pred-no-results" style="display:none">
          <td colspan="3" class="text-center text-muted py-6 text-[.9rem]"
            >No se encontró ningún participante.</td
          >
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  const input = document.getElementById("pred-search") as HTMLInputElement;
  const noResults = document.getElementById(
    "pred-no-results",
  ) as HTMLTableRowElement;

  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    const rows =
      document.querySelectorAll<HTMLTableRowElement>("tr[data-name]");
    let visible = 0;
    rows.forEach((row) => {
      const match = !q || row.dataset.name!.includes(q);
      row.style.display = match ? "" : "none";
      if (match) visible++;
    });
    noResults.style.display = visible === 0 ? "" : "none";
  });
</script>
