---
import { flagUrl } from '../data/teamFlags.ts';

interface Props {
  team: string;
  size?: number;
}

const { team, size = 18 } = Astro.props;
const src = flagUrl(team);
---

{
  src && (
    <img
      class="w-auto align-middle rounded-[2px] [box-shadow:0_0_0_1px_rgba(0,0,0,.25)]"
      src={src}
      alt={`Bandera de ${team}`}
      height={size}
      loading="lazy"
      style={`height:${size}px`}
    />
  )
}
