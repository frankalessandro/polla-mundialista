---
import { flagUrl } from '../data/teamFlags.ts';

interface Props {
  team: string;
  /** Altura de la bandera en px (el ancho se ajusta solo). */
  size?: number;
}

const { team, size = 18 } = Astro.props;
const src = flagUrl(team);
---

{
  src && (
    <img
      class="flag"
      src={src}
      alt={`Bandera de ${team}`}
      height={size}
      loading="lazy"
      style={`height:${size}px`}
    />
  )
}

<style>
	.flag {
		width: auto;
		border-radius: 2px;
		vertical-align: middle;
		box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.25);
	}
</style>
