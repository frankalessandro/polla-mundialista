---
interface Props {
  small?: boolean;
  label?: string;
}

const { small = false, label = 'En vivo' } = Astro.props;
---

<span class={`inline-flex items-center gap-1.5 font-bold uppercase tracking-[.05em] text-live bg-[rgba(255,93,122,.1)] border border-[rgba(255,93,122,.35)] rounded-full whitespace-nowrap ${small ? 'text-[.62rem] px-1.5 py-0' : 'text-[.72rem] px-2 py-0.5'}`}>
  <span class={`rounded-full bg-live dot ${small ? 'w-[.42rem] h-[.42rem]' : 'w-2 h-2'}`}></span>
  {label}
</span>

<style>
  .dot {
    animation: live-pulse 1.4s ease-out infinite;
  }
</style>
