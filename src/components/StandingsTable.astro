---
import type { StandingRow } from '../lib/scoring.ts';

interface Props {
  rows: StandingRow[];
}

const { rows } = Astro.props;
const medal = (i: number) => (i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '');
---

<table class="standings">
	<thead>
		<tr>
			<th class="num">#</th>
			<th>Participante</th>
			<th class="num">Pts</th>
			<th class="num" title="Marcadores exactos (5 pts)">Exactos</th>
			<th class="num" title="Resultados acertados (2 o 3 pts)">Aciertos</th>
			<th class="num">Jugados</th>
		</tr>
	</thead>
	<tbody>
		{
			rows.map((row, i) => (
				<tr style={`animation-delay:${Math.min(i * 0.025, 0.5)}s`} class="row">
					<td class="num">
						<span class={`rank ${medal(i)}`}>{i + 1}</span>
					</td>
					<td class="name">
						<a href={`/participante/${row.participantId}`}>{row.name}</a>
					</td>
					<td class="num pts">{row.total}</td>
					<td class="num soft">{row.exactScores}</td>
					<td class="num soft">{row.correctOutcomes}</td>
					<td class="num soft">{row.played}</td>
				</tr>
			))
		}
	</tbody>
</table>

<style>
	.row {
		animation: fadeUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.name a {
		color: var(--text);
		font-weight: 600;
	}

	.name a:hover {
		color: var(--primary);
	}

	.rank {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.6rem;
		height: 1.6rem;
		padding: 0 0.35rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--muted);
		background: var(--surface-2);
	}

	.rank.gold {
		background: linear-gradient(135deg, #ffd86b, #f7b955);
		color: #6b4e00;
	}

	.rank.silver {
		background: linear-gradient(135deg, #e9ecf5, #c7cdde);
		color: #4a4f63;
	}

	.rank.bronze {
		background: linear-gradient(135deg, #f3c08a, #e0a062);
		color: #6b3e15;
	}

	.pts {
		font-weight: 800;
		color: var(--primary);
		font-size: 1.05rem;
	}

	.soft {
		color: var(--muted);
	}
</style>
