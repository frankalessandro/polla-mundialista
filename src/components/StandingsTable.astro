---
import type { StandingRow } from '../lib/scoring.ts';
import { getRankClass } from '../lib/styles.ts';
import SortIcon from './SortIcon.astro';

interface Props {
  rows: StandingRow[];
}

const { rows } = Astro.props;
---

<div id="standings-wrapper" data-mode="simple">
  <div class="table-scroll">
    <table id="standings-table">
      <thead>
        <tr>
          <th class="num">#</th>
          <th class="min-w-36 whitespace-nowrap">Participante</th>
          <th class="num" data-col="pts" data-sort="desc" title="Puntos totales">
            Pts
            <SortIcon />
          </th>
          <th class="num" data-col="exactos" title="Marcadores exactos (5 pts) — desempate 1">
            Exactos
            <SortIcon />
          </th>
          <th class="num col-detail" data-col="tres" title="Ganador correcto + un gol acertado — desempate 2">
            3 pts
            <SortIcon />
          </th>
          <th class="num col-detail" data-col="dos" title="Ganador o empate simple — desempate 3">
            2 pts
            <SortIcon />
          </th>
          <th class="num col-detail" data-col="uno" title="Un gol acertado, resultado fallado — desempate 4">
            1 pt
            <SortIcon />
          </th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row, i) => (
            <tr
              style={`animation-delay:${Math.min(i * 0.025, 0.5)}s`}
              class="reveal"
              data-name={row.name.toLowerCase()}
              data-pts={row.total}
              data-exactos={row.exactScores}
              data-tres={row.threePointHits}
              data-dos={row.twoPointHits}
              data-uno={row.onePointHits}
            >
              <td class="num">
                <span class={`inline-flex items-center justify-center min-w-[1.6rem] h-[1.6rem] px-1.5 rounded-full font-bold text-[.85rem] ${getRankClass(i + 1)}`}>
                  {i + 1}
                </span>
              </td>
              <td class="min-w-36">
                <a href={`/participante/${row.participantId}`} class="text-text font-semibold hover:text-primary transition-colors whitespace-nowrap">
                  {row.name}
                </a>
              </td>
              <td class="num font-extrabold text-primary text-[1.05rem]">{row.total}</td>
              <td class="num text-muted">{row.exactScores}</td>
              <td class="num text-muted col-detail">{row.threePointHits}</td>
              <td class="num text-muted col-detail">{row.twoPointHits}</td>
              <td class="num text-muted col-detail">{row.onePointHits}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>

<script>
  const wrapper = document.getElementById('standings-wrapper') as HTMLElement;
  const table = document.getElementById('standings-table') as HTMLTableElement;
  const tbody = table.querySelector('tbody')!;
  let activeCol = 'pts';
  let activeDir: 'asc' | 'desc' = 'desc';

  // Listen for mode changes dispatched by the toggle outside this component.
  document.addEventListener('standings:mode', (e) => {
    wrapper.dataset.mode = (e as CustomEvent<string>).detail;
  });

  function sortBy(col: string, dir: 'asc' | 'desc') {
    activeCol = col;
    activeDir = dir;

    table.querySelectorAll<HTMLElement>('th[data-col]').forEach((th) => th.removeAttribute('data-sort'));
    table.querySelector<HTMLElement>(`th[data-col="${col}"]`)?.setAttribute('data-sort', dir);

    tbody.style.opacity = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const dataRows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr[data-name]'));
        dataRows.sort((a, b) => {
          const av = col === 'name' ? a.dataset.name! : Number(a.dataset[col]);
          const bv = col === 'name' ? b.dataset.name! : Number(b.dataset[col]);
          if (av < bv) return dir === 'asc' ? -1 : 1;
          if (av > bv) return dir === 'asc' ? 1 : -1;
          return 0;
        });
        dataRows.forEach((r) => tbody.appendChild(r));
        tbody.style.opacity = '1';
      });
    });
  }

  table.querySelector('thead')!.addEventListener('click', (e) => {
    const th = (e.target as Element).closest<HTMLElement>('th[data-col]');
    if (!th) return;
    const col = th.dataset.col!;
    const dir = activeCol === col && activeDir === 'desc' ? 'asc' : 'desc';
    sortBy(col, dir);
  });
</script>

<style>
  #standings-wrapper[data-mode="simple"] .col-detail { display: none; }
</style>
