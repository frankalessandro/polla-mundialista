---
// Panel con toggle para mostrar/ocultar columnas de desempate en StandingsTable
---

<div class="desempate-wrap reveal" style="animation-delay:.06s">
  <div class="desempate-panel">
    <span class="panel-text">
      <span class="panel-title">Criterios de desempate</span>
      <span class="panel-sub">Exactos · 3 pts · 2 pts · 1 pt</span>
    </span>
    <label class="toggle-label-wrap" aria-label="Mostrar columnas de desempate">
      <input type="checkbox" id="full-view-toggle" />
      <span class="track"><span class="thumb"></span></span>
    </label>
  </div>
</div>

<script>
  const toggle = document.getElementById('full-view-toggle') as HTMLInputElement;
  toggle.addEventListener('change', () => {
    document.dispatchEvent(new CustomEvent('standings:mode', {
      detail: toggle.checked ? 'full' : 'simple',
    }));
  });
</script>

<style>
  .desempate-wrap { position: relative; z-index: 10; }

  .desempate-panel {
    display: flex;
    align-items: center;
    gap: .85rem;
    border: 1px solid var(--border);
    border-radius: 1.1rem;
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    padding: .75rem 1.1rem;
    transition: border-color .2s ease;
  }
  .desempate-panel:has(input:checked) {
    border-color: var(--primary);
    background: var(--grad-soft);
  }

  .panel-text { display: flex; flex-direction: column; gap: .1rem; flex: 1; min-width: 0; }
  .panel-title { font-size: .95rem; font-weight: 600; color: var(--text); }
  .panel-sub { font-size: .76rem; font-weight: 500; color: var(--muted); letter-spacing: .02em; }

  .toggle-label-wrap { display: flex; align-items: center; cursor: pointer; flex-shrink: 0; }
  .toggle-label-wrap input { position: absolute; opacity: 0; width: 0; height: 0; }

  .track {
    position: relative;
    width: 3.4rem;
    height: 1.85rem;
    border-radius: 999px;
    background: #d9d2ef;
    border: 1px solid rgba(124, 92, 255, .22);
    box-shadow: inset 0 1px 3px rgba(110, 80, 190, .18);
    transition: background .25s ease, border-color .25s ease, box-shadow .25s ease;
    flex-shrink: 0;
  }
  .thumb {
    position: absolute;
    top: 50%;
    left: 3px;
    transform: translateY(-50%);
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 5px rgba(110, 80, 190, .35);
    transition: left .22s cubic-bezier(.34, 1.56, .64, 1), box-shadow .22s ease;
  }
  .desempate-panel input:checked ~ .track {
    background: var(--grad);
    border-color: transparent;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, .12), 0 0 0 3px rgba(124, 92, 255, .18);
  }
  .desempate-panel input:checked ~ .track .thumb {
    left: calc(100% - 1.6rem);
    box-shadow: 0 2px 6px rgba(124, 92, 255, .5);
  }
  .desempate-panel input:focus-visible ~ .track {
    box-shadow: 0 0 0 3px rgba(124, 92, 255, .35);
  }
</style>
