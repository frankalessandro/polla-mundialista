---
---

<div class="relative reveal z-10" style="animation-delay:.04s">
  <div class="card">
    <div class="flex items-center gap-2">
      <div class="relative flex-1">
        <svg
          class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none transition-colors peer-focus:text-primary"
          viewBox="0 0 20 20"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"></circle>
          <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
        <input
          id="standings-search"
          type="search"
          placeholder="Buscar participante…"
          autocomplete="off"
          spellcheck="false"
          class="peer w-full pl-10 pr-4 py-2.5 border-[1.5px] border-border rounded-xl bg-surface-2 text-text font-medium text-[.9rem] outline-none transition-[border-color,box-shadow,background] placeholder:text-muted placeholder:font-normal focus:bg-surface focus:border-primary focus:[box-shadow:0_0_0_3px_rgba(124,92,255,.14),var(--shadow-sm)] [&::-webkit-search-cancel-button]:hidden"
        />
      </div>

      <button
        id="tiebreaker-btn"
        aria-label="Criterios de desempate"
        aria-expanded="false"
        class="flex items-center justify-center w-9 h-9 rounded-xl border-[1.5px] border-border bg-surface-2 text-muted hover:text-primary hover:border-primary hover:bg-surface transition-[color,border-color,background] shrink-0"
      >
        <svg viewBox="0 0 20 20" width="16" height="16" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.6"/>
          <path d="M10 9v5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <circle cx="10" cy="6.5" r="0.9" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Popover lives OUTSIDE .card to avoid overflow:hidden clipping -->
  <div
    id="tiebreaker-popover"
    role="tooltip"
    hidden
    class="absolute right-0 top-[calc(100%+8px)] z-20 w-72 bg-surface border border-border rounded-2xl p-4 [box-shadow:var(--shadow-sm)] text-[.85rem]"
  >
    <p class="font-bold text-text mb-2 mt-0">Criterios de desempate</p>
    <ol class="m-0 pl-5 space-y-1.5 text-muted">
      <li><span class="text-text font-semibold">1°</span> Mayor número de marcadores exactos <span class="text-primary font-bold">(5 pts)</span></li>
      <li><span class="text-text font-semibold">2°</span> Mayor número de resultados acertados <span class="text-primary font-bold">(ganador / empate)</span></li>
      <li><span class="text-text font-semibold">3°</span> Los participantes definirán cómo resolver el empate</li>
    </ol>
  </div>
</div>

<script>
  const input = document.getElementById('standings-search') as HTMLInputElement;
  const btn = document.getElementById('tiebreaker-btn') as HTMLButtonElement;
  const popover = document.getElementById('tiebreaker-popover') as HTMLDivElement;

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    const rows = document.querySelectorAll<HTMLTableRowElement>('#standings-table tbody tr[data-name]');
    rows.forEach((row) => {
      row.style.display = !q || row.dataset.name!.includes(q) ? '' : 'none';
    });
  });

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = !popover.hidden;
    popover.hidden = open;
    btn.setAttribute('aria-expanded', String(!open));
  });

  document.addEventListener('click', (e) => {
    if (!btn.contains(e.target as Node) && !popover.contains(e.target as Node)) {
      popover.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !popover.hidden) {
      popover.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.focus();
    }
  });
</script>
