---
---

<div class="relative reveal z-10" style="animation-delay:.04s">
  <div class="card">
    <div class="relative">
      <svg
        class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none transition-colors peer-focus:text-primary"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"></circle>
        <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
      </svg>
      <input
        id="standings-search"
        type="search"
        placeholder="Buscar participante…"
        autocomplete="off"
        spellcheck="false"
        class="peer w-full pl-10 pr-4 py-2.5 border-[1.5px] border-border rounded-xl bg-surface-2 text-text font-medium text-[.9rem] outline-none transition-[border-color,box-shadow,background] placeholder:text-muted placeholder:font-normal focus:bg-surface focus:border-primary focus:[box-shadow:0_0_0_3px_rgba(124,92,255,.14),var(--shadow-sm)] [&::-webkit-search-cancel-button]:hidden"
      />
    </div>
  </div>
</div>

<script>
  const input = document.getElementById('standings-search') as HTMLInputElement;

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    const rows = document.querySelectorAll<HTMLTableRowElement>('#standings-table tbody tr[data-name]');
    rows.forEach((row) => {
      row.style.display = !q || row.dataset.name!.includes(q) ? '' : 'none';
    });
  });
</script>
